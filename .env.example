# OpenAI API Configuration (for script generation)
OPENAI_API_KEY=sk-your-api-key-here

# ElevenLabs API Configuration (for TTS)
ELEVENLABS_API_KEY=your-elevenlabs-api-key-here

# Voice Configuration
# ElevenLabs voice IDs - these are examples, you can browse voices at elevenlabs.io/voice-library
# For Italian speakers, try: Valentino, Gianni, Domi (multilingual), or create custom voices
TEACHER_VOICE_ID=XB0fDUnXU5powFXDhCwa  # Example: Italian male voice
STUDENT_VOICE_ID=pNInz6obpgDQGcFmaJgB  # Example: Adam (clear English/Italian)

# Alternative: Use voice names instead of IDs (will auto-lookup)
# TEACHER_VOICE_NAME=Valentino
# STUDENT_VOICE_NAME=Adam

# Paths
ITALIAN_NOTES_PATH=/Users/andyjones/projects/personal/andyjones-life/areas/italian

# Server Configuration (for later deployment)
SERVER_USER=ubuntu
SERVER_HOST=podcast.andyjones.co
SERVER_PATH=/var/www/podcast

# Episode Configuration
TARGET_DURATION_MINUTES=15
